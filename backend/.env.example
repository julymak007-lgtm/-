# ========================================
# SIPLACE SX2 后端环境配置
# ========================================

# FastAPI 服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# ========================================
# Supabase 数据库配置
# ========================================
# 从 Supabase 项目设置中获取这些值
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 数据库直接连接（可选，用于Python训练脚本）
SUPABASE_HOST=db.your_project_id.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_database_password

# ========================================
# 模型训练配置
# ========================================
# 是否使用真实后端训练（false = 模拟模式，true = 真实Python训练）
USE_REAL_TRAINING=false

# 训练队列配置
TRAINING_QUEUE_DIR=./backend/training/queue
TRAINING_RESULTS_DIR=./backend/training/results
TRAINING_MODELS_DIR=./backend/models

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ========================================
# CORS 配置
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
